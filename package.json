{
  "name": "kaptano",
  "private": true,
  "scripts": {
    "postinstall": "pnpm db:generate",
    "dev": "turbo dev",
    "dev:clean": "lsof -ti:3000,3001,8080 | xargs kill -9 2>/dev/null; rm -rf apps/web/.next && turbo dev",
    "build": "pnpm db:generate && pnpm --filter @kaptano/web build",
    "build:all": "turbo build",
    "lint": "turbo lint",
    "db:generate": "pnpm --filter @kaptano/db generate",
    "db:migrate": "pnpm --filter @kaptano/db migrate",
    "db:push": "pnpm --filter @kaptano/db push",
    "db:seed": "pnpm --filter @kaptano/db seed",
    "db:studio": "pnpm --filter @kaptano/db studio",
    "test": "pnpm --filter @kaptano/web test"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": "22.x"
  }
}
